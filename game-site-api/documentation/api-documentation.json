  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "username",
          "email",
          "password"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "email",
          "password",
          "createdAt"
        ]
      },
      "BasicUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "minimum": 1
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "email",
          "createdAt"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "CreateChallengeDto": {
        "type": "object",
        "properties": {
          "senderId": {
            "type": "number",
            "minimum": 1
          },
          "receiverId": {
            "type": "number",
            "minimum": 1
          },
          "gameType": {
            "type": "string",
            "enum": [
              "tic-tac-toe",
              "connect 4"
            ]
          }
        },
        "required": [
          "senderId",
          "receiverId",
          "gameType"
        ]
      },
      "Challenge": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "senderId": {
            "type": "number"
          },
          "receiverId": {
            "type": "number"
          },
          "gameType": {
            "enum": [
              "tic-tac-toe",
              "connect 4"
            ],
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "senderId",
          "receiverId",
          "gameType",
          "createdAt"
        ]
      },
      "DetailedChallengeDto": {
        "type": "object",
        "properties": {
          "senderId": {
            "type": "number",
            "minimum": 1
          },
          "senderName": {
            "type": "string"
          },
          "receiverId": {
            "type": "number",
            "minimum": 1
          },
          "receiverName": {
            "type": "string"
          },
          "gameType": {
            "enum": [
              "tic-tac-toe",
              "connect 4"
            ],
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "senderId",
          "senderName",
          "receiverId",
          "receiverName",
          "gameType",
          "createdAt"
        ]
      },
      "UpdateChallengeDto": {
        "type": "object",
        "properties": {
          "senderId": {
            "type": "number",
            "minimum": 1
          },
          "receiverId": {
            "type": "number",
            "minimum": 1
          },
          "gameType": {
            "enum": [
              "tic-tac-toe",
              "connect 4"
            ],
            "type": "string"
          }
        },
        "required": [
          "senderId",
          "receiverId",
          "gameType"
        ]
      },
      "CreateGameDto": {
        "type": "object",
        "properties": {
          "player1Id": {
            "type": "number",
            "minimum": 1
          },
          "player2Id": {
            "type": "number",
            "minimum": 1
          },
          "gameType": {
